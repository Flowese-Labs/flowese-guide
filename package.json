{
  "name": "flowese-guide",
  "version": "1.0.0",
  "description": "A self-contained onboarding guide component for interactive tooltips and step-by-step guidance",
  "type": "module",
  "main": "./dist/flowese-guide.umd.js",
  "module": "./dist/flowese-guide.es.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/flowese-guide.css",
  "exports": {
    ".": {
      "import": "./dist/flowese-guide.es.js",
      "require": "./dist/flowese-guide.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/flowese-guide.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "onboarding",
    "guide",
    "tooltip",
    "react",
    "flowese",
    "user-experience",
    "tutorial"
  ],
  "author": "Flowese",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/css": "^11.11.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0"
  }
}